

fn clamp_int(x: int, lo: int, hi: int): int {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

fn clamp_f(x: double, lo: double, hi: double): double {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

fn lerp(a: double, b: double, t: double): double {
    return a + (b - a) * t;
}

fn sign_int(x: int): int {
    if x > 0 { return 1; }
    if x < 0 { return -1; }
    return 0;
}
