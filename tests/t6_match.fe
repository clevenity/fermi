import <std.io>;
fn grade(score: int) {
    match (score) {
        90..100 => io::print("A");
        80..89  => io::print("B");
        70..79  => io::print("C");
        60..69  => io::print("D");
        _       => io::print("F");
    }
}

fn main(): int {
    grade(95);
    grade(83);
    grade(72);
    grade(55);
    return 0;
}
