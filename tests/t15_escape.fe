import <std.io>;
import <std.string>;

fn main(): int {
    io::print("tab:\there");
    io::print("newline in string:\nsecond line");
    io::print("backslash: \\");
    io::print("quote: \"");
    io::print("hex: \x41\x42\x43");
    io::print("unicode: \u0048\u0065\u006C\u006C\u006F");
    io::print("unicode brace: \u{1F600}");
    io::print(r"raw: no \n escape here");
    io::print("""
triple
quoted
string""");
    let sep = 1_000_000;
    io::print(sep);
    let hex = 0xFF_AA;
    io::print(hex);
    let p: *int = null;
    let ok: bool = (p == null);
    io::print(ok);
    let ch1: char = '\t';
    let ch2: char = '\n';
    let ch3: char = '\x41';
    io::print(ch1); io::print(ch3); io::print(ch2);
    return 0;
}
