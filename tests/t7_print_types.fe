import <std.io>;
fn main(): int {
    io::print(42);
    io::print(" ");
    io::print(3.14);
    io::print(" ");
    io::print(true);
    io::print(" ");
    io::print('Z');
    io::print(" ");
    io::print("fermi");
    io::print("\n");
    io::print(100);
    io::print(2.718);
    io::print(false);
    return 0;
}
