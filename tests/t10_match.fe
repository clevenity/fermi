import <std.io>;

fn classify(n: int): int {
    match (n) {
        0       => return 0;
        1..5    => return 1;
        6..10   => return 2;
        _       => return 3;
    }
}

fn grade(score: int) {
    match (score) {
        90..100 => io::print("A");
        80..89  => io::print("B");
        70..79  => io::print("C");
        60..69  => io::print("D");
        _       => io::print("F");
    }
}

fn bool_match(b: bool) {
    match (b) {
        true  => io::print("yes");
        false => io::print("no");
    }
}

fn main(): int {
    io::print(classify(0));
    io::print(classify(3));
    io::print(classify(7));
    io::print(classify(99));

    grade(95);
    grade(83);
    grade(72);
    grade(65);
    grade(40);

    bool_match(true);
    bool_match(false);

    return 0;
}
