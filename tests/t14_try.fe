import <std.io>;
fn safe_div(a: int, b: int): Result<int, int> {
    if (b == 0) {
        return Err(99);
    }
    return Ok(a / b);
}

fn compute(x: int): Result<int, int> {
    let v: int = safe_div(x, 2)?;
    return Ok(v + 1);
}

fn main(): int {
    let r: Result<int, int> = compute(10);
    io::print("try propagation ok");
    return 0;
}
