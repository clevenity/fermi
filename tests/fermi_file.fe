import <std.io>;
import <std.math>;

struct Point {
    x: float;
    y: float;
}

fn point_dist(a: Point, b: Point): float {
    let dx = a.x - b.x;
    let dy = a.y - b.y;
    return math::sqrt(dx * dx + dy * dy);
}

fn fib(n: int): int {
    if (n <= 1) { return n; }
    return fib(n - 1) + fib(n - 2);
}

fn sum_to(n: long): long {
    mut acc: long = 0;
    mut i: long = 1;
    while (i <= n) {
        acc = acc + i;
        i = i + 1;
    }
    return acc;
}

fn collatz_steps(n: long): long {
    mut x: long = n;
    mut steps: long = 0;
    while (x != 1) {
        if (x % 2 == 0) {
            x = x / 2;
        } else {
            x = x * 3 + 1;
        }
        steps = steps + 1;
    }
    return steps;
}

fn main(): int {
    io::println("=== fermi file.fe ===");

    let a = Point { x: 0.0, y: 0.0 };
    let b = Point { x: 3.0, y: 4.0 };
    let d = point_dist(a, b);
    io::print("dist(0,0 -> 3,4) = ");
    io::println(d);

    io::print("fib(10) = ");
    io::println(fib(10));

    io::print("sum(1..100) = ");
    io::println(sum_to(100));

    io::print("collatz_steps(27) = ");
    io::println(collatz_steps(27));

    io::print("sqrt(2) = ");
    io::println(math::sqrt(2.0));

    io::println("done.");
    return 0;
}
