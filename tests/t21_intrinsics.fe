comptime let BUFFER_SIZE: int = 1024;
comptime let MAX_CONNECTIONS: int = BUFFER_SIZE * 8;

fn divide(a: int, b: int) -> int {
    @assert(b != 0, "division by zero");
    return a / b;
}

fn check_bounds(idx: int, limit: int) -> int {
    if (idx >= limit) {
        @panic("index out of bounds");
    }
    return idx;
}

fn type_sizes() -> long {
    let si: long = @sizeof(int);
    let sd: long = @sizeof(double);
    let sb: long = @sizeof(bool);
    return si + sd + sb;
}

fn main() -> int {
    let bs: long = BUFFER_SIZE;
    let mc: long = MAX_CONNECTIONS;
    let _ = bs;
    let _ = mc;
    let r: int = divide(10, 2);
    let _ = r;
    let sz: long = type_sizes();
    let _ = sz;
    let idx: int = check_bounds(3, 10);
    let _ = idx;
    return 0;
}
