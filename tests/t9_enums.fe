import <std.io>;

enum Option {
    Some(int),
    None,
}

enum Direction {
    North,
    South,
    East,
    West,
}

enum Shape {
    Circle(int),
    Square(int),
    Triangle(int),
}

fn describe_direction(d: Direction) {
    match (d) {
        North => io::print("north");
        South => io::print("south");
        East  => io::print("east");
        West  => io::print("west");
        _     => io::print("unknown");
    }
}

fn area(s: Shape): int {
    match (s) {
        Circle(r)    => return r * r;
        Square(side) => return side * side;
        Triangle(b)  => return b;
        _            => return 0;
    }
}

fn unwrap_or(opt: Option, default_val: int): int {
    match (opt) {
        Some(v) => return v;
        None    => return default_val;
        _       => return default_val;
    }
}

fn main(): int {
    let s = Some(42);
    let n = None;

    io::print(unwrap_or(s, 0));
    io::print(unwrap_or(n, 99));

    describe_direction(North);
    describe_direction(East);

    let c = Circle(7);
    let sq = Square(4);
    io::print(area(c));
    io::print(area(sq));

    return 0;
}
