import <std.io>;
fn main(): int {
    let i: int = 42;
    let f: float = 3.14;
    let b: bool = true;
    let c: char = 'X';
    let s: str = "hello";
    let l: long = 1000000L;
    io::print(i);
    io::print(f);
    io::print(b);
    io::print(c);
    io::print(s);
    io::print(l);
    return 0;
}
